generator client {
  provider = "prisma-client-js"
}

datasource db {
  // SQLite for local dev — change provider to "postgresql" and update
  // DATABASE_URL for production.
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(cuid())
  email              String?  @unique
  passwordHash       String?
  suiAddress         String   @unique
  encryptedPrivateKey String?  // null for wallet-auth (non-custodial) users
  custodial          Boolean  @default(false)
  srePoints          Int      @default(0)
  hasInverterBonus   Boolean  @default(false) // guards the one-time 3-SRE connection bonus
  createdAt          DateTime @default(now())
  inverters          Inverter[]
  certificates       Certificate[]
}

model Inverter {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id])
  brand               String   // "solaredge" | "growatt" | "deye" | "huawei" | "mock"
  label               String
  encryptedCredentials String  // JSON blob, AES-256-GCM encrypted
  status              String   @default("active") // "active" | "error"
  createdAt           DateTime @default(now())
  certificates        Certificate[]
}

model Certificate {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  inverterId    String
  inverter      Inverter @relation(fields: [inverterId], references: [id])
  productionDay Int      // YYYYMMDD
  wattHours     Int
  walrusBlobId  String
  certObjectId  String   // Sui object ID of the minted SubCertificate
  txDigest      String
  mintedAt      DateTime @default(now())

  @@unique([userId, productionDay]) // DB-level idempotency guard
}

model WalletNonce {
  id        String   @id @default(cuid())
  address   String   @unique
  nonce     String
  expiresAt DateTime
}
